# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development   # set to 'production' on Render/Railway/etc.

# ─── Database ─────────────────────────────────────────────────────────────────
# Get your free MongoDB Atlas URI at https://cloud.mongodb.com
MONGO_URI=mongodb://localhost:27017/pucit-resourcehub

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend (used for CORS whitelist)
CLIENT_URL=http://localhost:5173

# ─── Cloudinary (File Storage) ────────────────────────────────────────────────
# Sign up free at https://cloudinary.com and find these in your dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
